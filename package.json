{
    "name": "akiles-react-native",
    "version": "2.3.2",
    "description": "Akiles React Native",
    "main": "./lib/module/index.js",
    "types": "./lib/typescript/src/index.d.ts",
    "exports": {
        ".": {
            "source": "./src/index.tsx",
            "types": "./lib/typescript/src/index.d.ts",
            "default": "./lib/module/index.js"
        },
        "./package.json": "./package.json"
    },
    "files": [
        "src",
        "lib",
        "android",
        "ios",
        "cpp",
        "*.podspec",
        "react-native.config.js",
        "!ios/build",
        "!android/build",
        "!android/gradle",
        "!android/gradlew",
        "!android/gradlew.bat",
        "!android/local.properties",
        "!**/__tests__",
        "!**/__fixtures__",
        "!**/__mocks__",
        "!**/.*"
    ],
    "scripts": {
        "example": "yarn workspace akiles-react-native-example",
        "test": "jest",
        "typecheck": "tsc",
        "lint": "eslint \"**/*.{js,ts,tsx}\"",
        "clean": "del-cli android/build example/android/build example/android/app/build example/ios/build lib",
        "prepare": "bob build",
        "release": "release-it --only-version"
    },
    "keywords": [
        "react-native",
        "ios",
        "android"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/akiles/akiles-react-native.git"
    },
    "author": "Akiles <support@akiles.app> (https://akiles.app)",
    "license": "MIT",
    "bugs": {
        "url": "https://github.com/akiles/akiles-react-native/issues"
    },
    "homepage": "https://dev.akiles.app/sdk/react-native/",
    "publishConfig": {
        "registry": "https://registry.npmjs.org/"
    },
    "devDependencies": {
        "@commitlint/config-conventional": "^20.5.0",
        "@eslint/compat": "^2.0.5",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "^10.0.1",
        "@evilmartians/lefthook": "^2.1.6",
        "@react-native-community/cli": "20.1.3",
        "@react-native/babel-preset": "0.85.2",
        "@react-native/eslint-config": "^0.85.2",
        "@release-it/conventional-changelog": "^11.0.0",
        "@types/jest": "^30.0.0",
        "@types/react": "^19.2.14",
        "commitlint": "^20.5.0",
        "del-cli": "^7.0.0",
        "eslint": "^10.2.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.5",
        "jest": "^30.3.0",
        "prettier": "^3.8.3",
        "react": "19.2.3",
        "react-native": "0.85.2",
        "react-native-builder-bob": "^0.41.0",
        "release-it": "^20.0.0",
        "turbo": "^2.9.6",
        "typescript": "^6.0.3"
    },
    "peerDependencies": {
        "react": "*",
        "react-native": "*"
    },
    "workspaces": [
        "example"
    ],
    "packageManager": "yarn@3.6.1",
    "jest": {
        "preset": "react-native",
        "modulePathIgnorePatterns": [
            "<rootDir>/example/node_modules",
            "<rootDir>/lib/"
        ]
    },
    "commitlint": {
        "extends": [
            "@commitlint/config-conventional"
        ]
    },
    "release-it": {
        "git": {
            "commitMessage": "chore: release ${version}",
            "tagName": "v${version}"
        },
        "npm": {
            "publish": true
        },
        "github": {
            "release": true
        },
        "plugins": {
            "@release-it/conventional-changelog": {
                "preset": {
                    "name": "angular"
                }
            }
        }
    },
    "prettier": {
        "quoteProps": "consistent",
        "singleQuote": true,
        "tabWidth": 2,
        "trailingComma": "es5",
        "useTabs": false
    },
    "react-native-builder-bob": {
        "source": "src",
        "output": "lib",
        "targets": [
            [
                "module",
                {
                    "esm": true
                }
            ],
            [
                "typescript",
                {
                    "project": "tsconfig.build.json"
                }
            ]
        ]
    },
    "codegenConfig": {
        "name": "AkilesSpec",
        "type": "modules",
        "jsSrcsDir": "src",
        "android": {
            "javaPackageName": "app.akiles.reactnative"
        }
    },
    "create-react-native-library": {
        "languages": "kotlin-objc",
        "type": "turbo-module",
        "version": "0.50.3"
    },
    "typedocOptions": {
        "entryPoints": [
            "src/index.tsx"
        ]
    }
}
